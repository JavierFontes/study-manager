{
  "name": "study-manager",
  "version": "1.0.0",
  "description": "Administrador de archivos de estudio con IA",
  "main": "electron.cjs",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.tuapp.studymanager",
    "productName": "StudyOS",
    "forceCodeSigning": false,
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.cjs",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend",
        "filter": ["**/*"]
      },
      {
        "from": "../backend/.env",
        "to": "backend/.env"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "public/hat.ico",
      "sign": null
    }
  },
  "dependencies": {
    "axios": "^1.7.0",
    "katex": "^0.16.0",
    "pdfjs-dist": "^4.8.69",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.0",
    "react-pdf": "^10.4.1",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.0",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.1",
    "wait-on": "^8.0.0"
  }
}